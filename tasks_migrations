create policy "tasks_select_creator_or_project_shared"
on public.tasks
for select
to authenticated
using (
  "creatorID" = auth.uid()
  or exists (
    select 1
    from public.task_projects p
    where p."recordID" = tasks."projectID"
      and (
        p."creatorID" = auth.uid()
        or exists (
          select 1
          from public.task_projects_shared ps
          where ps."projectID" = p."recordID"
            and ps."sharedToID" = auth.uid()
        )
      )
  )
);
 
create policy "tasks_insert_creator_or_project_shared"
on public.tasks
for insert
to authenticated
with check (
  "creatorID" = auth.uid()
  and (
    "projectID" is null
    or exists (
      select 1
      from public.task_projects p
      where p."recordID" = tasks."projectID"
        and (
          p."creatorID" = auth.uid()
          or exists (
            select 1
            from public.task_projects_shared ps
            where ps."projectID" = p."recordID"
              and ps."sharedToID" = auth.uid()
          )
        )
    )
  )
);
 
